# ==============================================================================
# IKIGAI 2026 Environment Variables
# ==============================================================================

# SUPABASE
# The URL of your Supabase project (e.g. https://xyzcompany.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# The anonymous public API key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The service role key (Never expose this on the client side!)
SUPABASE_SERVICE_ROLE_KEY=

# APP SETTINGS
# The base URL of the deployed application (e.g. https://ikigai2026.com)
NEXT_PUBLIC_SITE_URL=

# NODE_ENV will automatically be set to 'production' by Vercel
# NODE_ENV=

# MONITORING (Sentry / Vercel)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# OAUTH (Google)
# Configure these in Supabase Auth settings, usually not needed here 
# unless you implement custom server-side OAuth flows.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
